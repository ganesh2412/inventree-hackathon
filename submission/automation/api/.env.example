# InvenTree API Automation - Environment Variables
# Copy this file to .env and fill in your values

# Base URL of your InvenTree instance (no trailing slash)
# Default: http://localhost (for Docker Compose setup)
INVENTREE_BASE_URL=http://localhost

# Your InvenTree API token
# Get it from: http://localhost/api/user/token/ (when logged in)
# Or from: InvenTree UI -> User Profile -> API Tokens
INVENTREE_API_TOKEN=your-api-token-here
